# Curated URDF snapshots live under data/urdf_snapshots/<family>/<snapshot_id>/ (tracked).
# Ignore accidental nested git checkouts or colcon trees dropped under data/.
data/urdf_snapshots/**/.git/
data/urdf_snapshots/**/install/
data/urdf_snapshots/**/build/
data/urdf_snapshots/**/log/

# Large local render batches (keep canonical previews like data/renders/so101_*/*.png tracked)
data/renders/_bulk/
data/raw_labels/
# Optional: ignore local annotation trials
# data/labels/by_annotator/
# Local SQLite artifacts
*.sqlite
*.sqlite3
*.db
*.db-journal
*.sqlite-journal
*.sqlite3-journal
*.sqlite-wal
*.sqlite3-wal
*.sqlite-shm
*.sqlite3-shm
*.zip
*.bag
